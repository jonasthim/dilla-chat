# dilla-turn server configuration

# Listen address and port
DILLA_TURN_LISTEN_ADDR=0.0.0.0
DILLA_TURN_PORT=3478

# TLS for TURNS (leave empty to disable)
DILLA_TURN_TLS_PORT=5349
DILLA_TURN_TLS_CERT=
DILLA_TURN_TLS_KEY=

# TURN realm (must match client expectations)
DILLA_TURN_REALM=dilla

# HMAC shared secret for credential validation
# Must match DILLA_TURN_SHARED_SECRET on the Dilla main server
DILLA_TURN_SHARED_SECRET=REPLACE_WITH_STRONG_RANDOM_SECRET

# UDP relay port range (must be open on firewall)
DILLA_TURN_RELAY_MIN_PORT=49152
DILLA_TURN_RELAY_MAX_PORT=65535

# Public IP that clients will use to reach this TURN server
DILLA_TURN_PUBLIC_IP=YOUR_PUBLIC_IP

# Health check HTTP endpoint
DILLA_TURN_HEALTH_PORT=8081

# Log level (debug/info/warn/error)
DILLA_TURN_LOG_LEVEL=info
