# Dilla server configuration

# HTTP/WebSocket listen port
DILLA_PORT=8080

# Directory for SQLite database and uploaded files
DILLA_DATA_DIR=./data

# Passphrase used to encrypt the SQLite database (SQLCipher)
DILLA_DB_PASSPHRASE=REPLACE_WITH_STRONG_RANDOM_PASSPHRASE

# TLS certificate and key (leave empty to disable TLS)
DILLA_TLS_CERT=
DILLA_TLS_KEY=

# Comma-separated list of federation peer URLs (e.g. https://peer1.example.com,https://peer2.example.com)
DILLA_PEERS=

# TURN relay for voice chat
# Mode: "self-hosted" (recommended) or "cloudflare" (legacy)
# DILLA_TURN_MODE=self-hosted
# DILLA_TURN_SHARED_SECRET=REPLACE_WITH_STRONG_RANDOM_SECRET
# DILLA_TURN_URLS=turn:your-turn-server:3478,turns:your-turn-server:5349
# DILLA_TURN_TTL=86400

# Legacy Cloudflare TURN (set DILLA_TURN_MODE=cloudflare to use)
DILLA_CF_TURN_KEY_ID=
DILLA_CF_TURN_API_TOKEN=

# OpenTelemetry observability (traces + metrics + logs)
# DILLA_OTEL_ENABLED=false
# DILLA_OTEL_PROTOCOL=http                           # "http" or "grpc"
# DILLA_OTEL_ENDPOINT=localhost:4318                  # OTLP endpoint
# DILLA_OTEL_HTTP_ENDPOINT=                           # dedicated HTTP endpoint (for browser telemetry proxy)
# DILLA_OTEL_INSECURE=true                            # set false for TLS endpoints
# DILLA_OTEL_SERVICE_NAME=dilla-server
# DILLA_OTEL_API_KEY=                                 # auth header value
# DILLA_OTEL_API_HEADER=                              # auth header name (e.g. x-honeycomb-team)
#
# Honeycomb example:
#   DILLA_OTEL_ENDPOINT=api.honeycomb.io
#   DILLA_OTEL_INSECURE=false
#   DILLA_OTEL_API_HEADER=x-honeycomb-team
#   DILLA_OTEL_API_KEY=your-honeycomb-api-key
